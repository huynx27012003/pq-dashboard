    // ========================================
    // Navigation Functions for Sidebar
    // ========================================
    
    // Show embedded content in iframe
    function showEmbeddedContent(url) {
        // Hide dashboard content, show iframe container
        $('#dashboardContent').hide();
        $('#embeddedContentContainer').show();
        
        // Load URL in iframe
        var iframe = $('#embeddedContentFrame');
        iframe.attr('src', url);
        
    }
    
    // Show dashboard content (hide iframe)
    function showDashboard() {
        // Hide iframe, show dashboard content
        $('#embeddedContentContainer').hide();
        $('#embeddedContentFrame').attr('src', ''); // Clear iframe
        $('#dashboardContent').show();
        
        // Update header and reset active menu
        setActiveMenu('menu-dashboard', 'Disturbance Analytics', 'Dashboard');
    }
    
    function showSystemEvents() {
        // Load Event Search in embedded iframe
        var url = '@Url.Action("Home2", "Main")/EventSearch';
        showEmbeddedContent(url);
        setActiveMenu('menu-system-events', 'Disturbance Analytics', 'System Events');
    }

    function showMeterList() {
        // Load Meter Activity in embedded iframe  
        var url = '@Url.Action("Home2", "Main")/MeterActivity';
        showEmbeddedContent(url);
        setActiveMenu('menu-meter-list', 'Disturbance Analytics', 'Meter List');
    }

