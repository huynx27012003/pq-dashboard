    function setActiveMenu(menuId, moduleName, pageName) {
        $('.menu-item').removeClass('active');
        $('#' + menuId).addClass('active');
        $('#currentPageTitle').text(moduleName + ' / ' + pageName);
    }

    // Reset to Dashboard when selecting Dashboard menu
    $(document).ready(function() {
        $('#menu-dashboard').on('click', function(e) {
            e.preventDefault();
            $('#application-tabs').tabs('option', 'active', 1); // Events tab
            setActiveMenu('menu-dashboard', 'Disturbance Analytics', 'Dashboard');
        });
    });
