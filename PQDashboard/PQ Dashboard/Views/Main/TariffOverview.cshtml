        </div>
    </div>

    <script>
        (function () {
            window.showFaultInfo = async function(start, end) {
                const modalContent = document.getElementById('fault-modal-content');
                const titleEl = document.getElementById('fault-info-title');
                const summaryId = document.getElementById('modal-summary-id');
                const summaryRange = document.getElementById('modal-summary-range');
                const summaryScenario = document.getElementById('modal-summary-scenario');
                const closeBtn = document.getElementById('close-fault-modal');

                if (!modalContent) return;

                // Set title and summary placeholders
                if (titleEl) titleEl.textContent = `Meter Status - ${new Date(start).toLocaleString()}`;
                if (summaryRange) summaryRange.textContent = `${new Date(start).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})} - ${new Date(end).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}`;
                
                modalContent.innerHTML = '<div style="text-align:center; padding:40px;"><div class="loader-ring" style="border-top-color:var(--primary-color); width:30px; height:30px;"></div><p style="margin-top:10px; color:var(--text-secondary);">Fetching faulty meter data...</p></div>';
                
                // Close button handler 
                if (closeBtn) {
                    closeBtn.onclick = () => {
                        if (window.$ && $.fn.modal) {
                            $('#fault-info-modal').modal('hide');
                        } else {
                            const modal = document.getElementById('fault-info-modal');
                            if (modal) {
                                modal.style.display = 'none';
                                modal.classList.remove('in', 'show');
                            }
                        }
                    };
                }

                // Show modal (using jQuery/Bootstrap)
                if (window.$ && $.fn.modal) {
                    $('#fault-info-modal').modal('show');
                } else {
                    const modal = document.getElementById('fault-info-modal');
                    if (modal) {
                        modal.style.display = 'block';
                        modal.classList.add('in', 'show');
                        modal.style.opacity = '1';
                    }
                }

                try {
                    const res = await fetch(`${CONFIG.baseUrl}/faults/by-window?window_start_ts=${encodeURIComponent(start)}&window_end_ts=${encodeURIComponent(end)}`);
                    if (!res.ok) {
                        if (res.status === 404) {
                            modalContent.innerHTML = '<div style="text-align:center; padding:40px; color:var(--text-secondary);"><i class="fa fa-info-circle" style="font-size:30px; margin-bottom:10px;"></i><p>No fault record found for this specific window.</p></div>';
                        } else {
                            throw new Error('Failed to fetch fault data');
                        }
                        return;
                    }
                    
                    const data = await res.json();
                    
                    // Update summary info
                    if (summaryId) summaryId.textContent = data.id || 'N/A';
                    if (summaryScenario) {
                        summaryScenario.textContent = data.scenario_code || 'N/A';
                        summaryScenario.className = `scenario-pill ${data.scenario_code === 'ALL_OK' ? 'normal' : 'warning'}`;
                    }
                    
                    if (!data.faults || data.faults.length === 0) {
                        modalContent.innerHTML = '<div style="text-align:center; padding:40px; color:var(--text-secondary);"><i class="fa fa-check-circle" style="font-size:30px; margin-bottom:10px; color:var(--success-color);"></i><p>No faulty meters recorded for this period.</p></div>';
                        return;
                    }

                    modalContent.innerHTML = `
                        <div class="table-responsive" style="max-height: 400px;">
                            <table class="table" style="margin-bottom:0;">
                                <thead style="background: #fdfdfd;">
                                    <tr>
                                        <th style="border-top:none; color:#64748b; font-size:11px; text-align: center;">METER SERIAL</th>
                                        <th style="border-top:none; color:#64748b; font-size:11px; text-align: center;">METER NAME</th>
                                        <th style="border-top:none; color:#64748b; font-size:11px; text-align: center;">FAULT START</th>
                                        <th style="border-top:none; color:#64748b; font-size:11px; text-align: center;">FAULT END</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${data.faults.map(f => `
                                        <tr>
                                            <td style="font-weight:400; padding:12px 16px; color:#64748b; text-align: center;">${f.meter_serial}</td>
                                            <td style="padding:12px 16px; font-weight:700; color:#001f8f; text-align: center;">${f.meter_name || 'N/A'}</td>
                                            <td style="padding:12px 16px; text-align: center;">${new Date(f.fault_start_ts).toLocaleString([], {year:'2-digit', month:'numeric', day:'numeric', hour:'numeric', minute:'2-digit'})}</td>
                                            <td style="padding:12px 16px; color:#64748b; text-align: center;">${f.fault_end_ts ? new Date(f.fault_end_ts).toLocaleString([], {year:'2-digit', month:'numeric', day:'numeric', hour:'numeric', minute:'2-digit'}) : '--'}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                } catch (e) {
                    console.error('Fault Modal Error:', e);
                    modalContent.innerHTML = `<div style="text-align:center; padding:40px; color:var(--danger-color);"><i class="fa fa-exclamation-triangle" style="font-size:30px; margin-bottom:10px;"></i><p>Error loading fault info: ${e.message}</p></div>`;
                }
            }
            // Configuration & State
            const CONFIG = {
                baseUrl: 'http://192.168.4.117:8001/api',
                pollingInterval: 30000 
            };

            const STATE = {
                meters: [],
                isPolling: false,
                currentEnergyPage: 'analysis',
                lastUpdateData: null,
                historyData: [],
                selectedMeterFilter: null,
                roles: [],
                sources: [],
                currentMeterId: null
            };

            // DOM Elements
            const elements = {
                meterTableBody: document.getElementById('meter-list-body'),
                meterManagementBody: document.getElementById('meter-management-body'),
                statTotal: document.getElementById('stat-total-meters'),
                statConnected: document.getElementById('stat-connected-meters'),
                statDisconnected: document.getElementById('stat-disconnected-meters'),
                statReading: document.getElementById('stat-reading-meters')
            };

            // --- API Service ---
            async function fetchAllMeters() {
                try {
                    // Try to load from cache first for immediate UI
                    const cached = localStorage.getItem('tariff_meters_cache');
                    if (cached) {
                        STATE.meters = JSON.parse(cached);
                        renderMeterList();
                        renderMeterManagement();
                        updateStats();
                    }

                    const response = await fetch(`${CONFIG.baseUrl}/get_all_meters_info`);
                    if (!response.ok) throw new Error('Failed to fetch meters');
                    const freshMeters = await response.json();
                    
                    // Merge fresh info with existing connected states if any
                    freshMeters.forEach(m => {
                        const existing = STATE.meters.find(em => em.meter_id == m.meter_id);
                        if (existing) {
                            m._isConnected = existing._isConnected;
                            m._statusText = existing._statusText;
                        }
                    });

                    STATE.meters = freshMeters;
                    localStorage.setItem('tariff_meters_cache', JSON.stringify(STATE.meters));
                    
                    renderMeterList();
                    renderMeterManagement();
                    updateStats();
                } catch (error) {
                    console.error('API Error (Meters):', error);
                }
            }

            async function pollStatus() {
                if (STATE.isPolling) return;
                STATE.isPolling = true;

                try {
                    const response = await fetch(`${CONFIG.baseUrl}/meter_loop_status`);
                    if (!response.ok) throw new Error('Failed to fetch status');
                    const statusData = await response.json();
                    
                    updateStatusUI(statusData);
                } catch (error) {
                    console.error('API Error (Status):', error);
                } finally {
                    STATE.isPolling = false;
                }
            }

            // --- UI Rendering ---
            function renderMeterList() {
                if (!elements.meterTableBody) return;
                elements.meterTableBody.innerHTML = STATE.meters.map(meter => {
                    const isConnected = meter._isConnected;
                    const rawStatus = (meter._statusText || '').toLowerCase();
                    const isFailed = rawStatus.includes('failed') || rawStatus === 'disconnected' || rawStatus === 'idle';
                    
                    const statusText = isConnected ? 'Connected' : (rawStatus.includes('failed') ? 'Failed' : meter._statusText || 'Disconnected');
                    const typeLabel = (meter.type || 'N/A').toUpperCase().includes('DMI') ? 'EDMI' : (meter.type || '--');
                    const safeName = (meter.meter_name || 'N/A').replace(/'/g, "\\'").replace(/"/g, '&quot;');

                    return `
                        <tr class="meter-row">
                            <td>${meter.serial_number}</td>
                            <td class="tm-link">
                                <a href="javascript:void(0)" onclick="openMeterDetail(${meter.meter_id}, '${safeName}')" style="color:var(--primary-color); font-weight:600; text-decoration:none;">
                                    ${meter.meter_name || 'N/A'}
                                </a>
                            </td>
                            <td>${meter.outstation || '--'}</td>
                            <td>${typeLabel}</td>
                            <td>${meter.model || '--'}</td>
                            <td id="status-cell-${meter.meter_id}">
                                <span class="status-pill ${isConnected ? 'connected' : (isFailed ? 'failed' : '')}">${statusText}</span>
                            </td>
                        </tr>
                    `;
                }).join('') || '<tr><td colspan="6" style="text-align:center;">No meters found.</td></tr>';
            }

            function renderMeterManagement() {
                if (!elements.meterManagementBody) return;
                if (!STATE.meters || STATE.meters.length === 0) {
                    elements.meterManagementBody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding: 40px;"><p style="color:var(--text-secondary);"><i class="fa fa-info-circle"></i> No meters found.</p></td></tr>';
                    return;
                }

                elements.meterManagementBody.innerHTML = STATE.meters.map(meter => {
                    const isConnected = meter._isConnected;
                    const rawStatus = (meter._statusText || '').toLowerCase();
                    const isFailed = rawStatus.includes('failed') || rawStatus.includes('timeout') || rawStatus === 'disconnected' || rawStatus === 'idle';
                    
                    const statusText = isConnected ? 'Connected' : (isFailed ? 'Failed' : meter._statusText || 'Disconnected');
                    
                    return `
                        <tr>
                            <td style="font-weight: 600;">${meter.serial_number}</td>
                            <td>${meter.meter_name || '--'}</td>
                            <td>${meter.username}</td>
                            <td id="mgt-status-${meter.meter_id}">
                                <span class="status-pill ${isConnected ? 'connected' : (isFailed ? 'failed' : '')}">${statusText}</span>
                            </td>
                            <td style="text-align: center;">
                                <button class="btn-action" style="color:var(--primary-color);" onclick="showMeterForm(${meter.meter_id})" title="Edit Meter"><i class="fa fa-pencil"></i></button>
                                <button class="btn-action delete" style="color:var(--danger-color);" onclick="deleteMeter(${meter.meter_id}, '${meter.serial_number}')" title="Delete Meter"><i class="fa fa-trash"></i></button>
                            </td>
                        </tr>
                    `;
                }).join('');
            }

            window.openMeterDetail = function(meterId, meterName) {
                const dashboardView = document.getElementById('tariff-dashboard-view');
                const detailView = document.getElementById('tariff-meter-detail');

                if (dashboardView && detailView) {
                    const m = STATE.meters.find(x => x.meter_id == meterId) || {};

                    dashboardView.style.display = 'none';
                    detailView.style.display = 'block';
                    STATE.currentMeterId = meterId;
                    
                    // Populate Meter Header
                    document.getElementById('mheader-name').textContent = meterName || m.meter_name || '--';
                    document.getElementById('mheader-sn').textContent = m.serial_number || '--';
                    document.getElementById('mheader-type').textContent = `M-${meterId}`;
                    
                    const isConnected = m._isConnected;
                    const rawStatus = (m._statusText || '').toLowerCase();
                    const isFailed = rawStatus.includes('failed') || rawStatus === 'disconnected' || rawStatus === 'idle';
                    
                    const stEl = document.getElementById('mheader-status');
                    if (stEl) {
                        stEl.textContent = isConnected ? 'Connected' : (isFailed ? 'Failed' : m._statusText || 'Disconnected');
                        stEl.className = 'status-pill ' + (isConnected ? 'connected' : (isFailed ? 'failed' : ''));
                    }

                    // Populate Info Grid
                    document.getElementById('minfo-imei').textContent = m.serial_number || '--';
                    const typeLabel = (m.type || 'N/A').toUpperCase().includes('DMI') ? 'EDMI ' + (m.model||'') : (m.model || m.type || 'Mk6E');
                    document.getElementById('minfo-type').textContent = typeLabel;
                    
                    const lastUpd = localStorage.getItem('tariff_last_status') ? new Date().toLocaleString([], {year:'numeric', month:'numeric', day:'numeric', hour:'numeric', minute:'2-digit'}) : 'N/A';
                    document.getElementById('minfo-updated').textContent = lastUpd;

                    // Fetch CT/VT Ratios
                    document.getElementById('minfo-ct-pri').textContent = '...';
                    document.getElementById('minfo-ct-sec').textContent = '...';
                    document.getElementById('minfo-vt-pri').textContent = '...';
                    document.getElementById('minfo-vt-sec').textContent = '...';

                    setTimeout(async () => {
                        try {
                            const endIso = new Date().toISOString();
                            const startIso = new Date(Date.now() - 365*24*3600*1000).toISOString(); // look back 1 year
                            const payload = {
                                meter_id: meterId,
                                columns: ['ct_ratio_primary', 'ct_ratio_secondary', 'vt_ratio_primary', 'vt_ratio_secondary'],
                                time_range: { start_utc: startIso, end_utc: endIso },
                                order: 'desc',
                                limit: 1
                            };
                            const res = await fetch(`${CONFIG.baseUrl}/query_data_by_time_range`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(payload)
                            });
                            if (res.ok) {
                                const resData = await res.json();
                                if (resData.data && resData.data.length > 0) {
                                    const row = resData.data[0];
                                    document.getElementById('minfo-ct-pri').textContent = row['ct_ratio_primary'] !== undefined && row['ct_ratio_primary'] !== null ? row['ct_ratio_primary'] : '--';
                                    document.getElementById('minfo-ct-sec').textContent = row['ct_ratio_secondary'] !== undefined && row['ct_ratio_secondary'] !== null ? row['ct_ratio_secondary'] : '--';
                                    document.getElementById('minfo-vt-pri').textContent = row['vt_ratio_primary'] !== undefined && row['vt_ratio_primary'] !== null ? row['vt_ratio_primary'] : '--';
                                    document.getElementById('minfo-vt-sec').textContent = row['vt_ratio_secondary'] !== undefined && row['vt_ratio_secondary'] !== null ? row['vt_ratio_secondary'] : '--';
                                } else {
                                    document.getElementById('minfo-ct-pri').textContent = 'N/A';
                                    document.getElementById('minfo-ct-sec').textContent = 'N/A';
                                    document.getElementById('minfo-vt-pri').textContent = 'N/A';
                                    document.getElementById('minfo-vt-sec').textContent = 'N/A';
                                }
                            }
                        } catch(e) { console.error('CT/VT Fetch Error', e); }
                    }, 50);

                    // Init Date pickers
                    const todayStr = new Date().toISOString().split('T')[0];
                    if (!document.getElementById('op-from').value) {
                        document.getElementById('op-from').value = todayStr;
                        document.getElementById('op-to').value = todayStr;
                        document.getElementById('pl-from').value = todayStr;
                        document.getElementById('pl-to').value = new Date(Date.now() + 86400000).toISOString().split('T')[0];
                    }

                    // Populate Survey Dropdown dynamically
                    const surveySel = document.getElementById('pl-survey');
                    if (surveySel) {
                        if (m.survey_type && Array.isArray(m.survey_type) && m.survey_type.length > 0) {
                            surveySel.innerHTML = m.survey_type.map(s => `<option value="${s}">${s}</option>`).join('');
                        } else {
                            surveySel.innerHTML = '<option value="LS02">LS02</option><option value="LS01">LS01</option>';
                        }
                    }

                    setTimeout(() => { 
                        updateOpMultiSelect(); 
                        updatePlMultiSelect(); 
                        fetchOperationMetrics();
                    }, 10);
                }
            };
            
            window.switchDetailTab = function(tabId, btnScope) {
                document.querySelectorAll('.detail-tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.detail-tab-content').forEach(c => c.classList.remove('active'));
                
                btnScope.classList.add('active');
                document.getElementById('dtab-' + tabId).classList.add('active');

                if (tabId === 'fn-readings') fetchFinalizedReadings();
            };

            window.toggleSurveyView = function() {
                const val = document.getElementById('pl-interval').value;
                const isSurvey = val === 'survey';
                
                document.querySelectorAll('.pl-time-picker').forEach(el => el.style.display = isSurvey ? 'block' : 'none');
                document.getElementById('pl-mode-label').textContent = isSurvey ? 'Survey' : 'Interval';
                
                document.getElementById('pl-table-main').style.display = isSurvey ? 'none' : 'table';
                document.getElementById('pl-table-survey').style.display = isSurvey ? 'table' : 'none';
                
                document.getElementById('pl-chart-title').innerHTML = isSurvey ? 'Load survey (LS02) 30m sampling interval' : 'Operating Parameters Chart';
            };

            window.togglePlMultiSelect = function(e) {
                if (e) e.stopPropagation();
                const drop = document.getElementById('pl-col-dropdown');
                if (drop) drop.classList.toggle('show');
            };

            window.updatePlMultiSelect = function() {
                const list = document.querySelectorAll('#pl-col-dropdown input[type="checkbox"]:checked');
                const textEl = document.getElementById('pl-col-text');
                if (!textEl) return;
                
                if (list.length === 0) {
                    textEl.textContent = 'None selected';
                } else if (list.length === 1) {
                    textEl.textContent = list[0].value;
                } else {
                    textEl.textContent = list[0].value + ', ' + (list[1] ? list[1].value.substring(0,8) + '...' : '...');
                }
            };
            
            document.addEventListener('click', function(e) {
                const wrapper = document.getElementById('pl-col-wrapper');
                const drop = document.getElementById('pl-col-dropdown');
                if (wrapper && drop && !wrapper.contains(e.target)) {
                    drop.classList.remove('show');
                }
                const wrapperOp = document.getElementById('op-col-wrapper');
                const dropOp = document.getElementById('op-col-dropdown');
                if (wrapperOp && dropOp && !wrapperOp.contains(e.target)) {
                    dropOp.classList.remove('show');
                }
            });

            window.handleOpCheckboxChange = function(cb) {
                const checkedBoxes = document.querySelectorAll('#op-col-dropdown input[type="checkbox"]:checked');
                if (checkedBoxes.length > 10) {
                    alert('You can select up to 10 parameters at a time.');
                    cb.checked = false;
                    return;
                }
                updateOpMultiSelect();
            };

            window.toggleOpMultiSelect = function(e) {
                if (e) e.stopPropagation();
                const drop = document.getElementById('op-col-dropdown');
                if (drop) drop.classList.toggle('show');
            };

            window.updateOpMultiSelect = function() {
                const list = document.querySelectorAll('#op-col-dropdown input[type="checkbox"]');
                const textEl = document.getElementById('op-col-text');
                const thElements = document.querySelectorAll('#op-table-main th');
                
                let checkedCount = 0;
                let firstChecked = null;
                let secondChecked = null;

                list.forEach((chk, i) => {
                    const isChecked = chk.checked;
                    if (isChecked) {
                        checkedCount++;
                        if (!firstChecked) firstChecked = chk;
                        else if (!secondChecked) secondChecked = chk;
                    }
                    if (thElements[i + 1]) {
                        thElements[i + 1].style.display = isChecked ? 'table-cell' : 'none';
                    }
                    const rows = document.querySelectorAll('#op-table-main tbody tr');
                    rows.forEach(row => {
                        const td = row.cells[i + 1];
                        if (td && td.colSpan === 1) {
                            td.style.display = isChecked ? 'table-cell' : 'none';
                        }
                    });
                });
                
                const emptyRowTd = document.querySelector('#op-table-main tbody tr:first-child td');
                if (emptyRowTd && emptyRowTd.parentElement.cells.length === 1) {
                    emptyRowTd.colSpan = checkedCount + 1;
                }
                
                if (!textEl) return;
                if (checkedCount === 0) {
                    textEl.textContent = 'None selected';
                } else if (checkedCount === 1) {
                    textEl.textContent = firstChecked.parentElement.textContent.trim();
                } else if (checkedCount === 52) {
                    textEl.textContent = '52 columns selected';
                } else {
                    textEl.textContent = firstChecked.parentElement.textContent.trim() + ', ' + (secondChecked ? secondChecked.parentElement.textContent.trim().substring(0,8) + '...' : '...');
                }
            };

            window.toggleOpSurveyView = function() {
                const val = document.getElementById('op-interval').value;
                const isSurvey = val === 'survey';
                
                document.getElementById('op-time-from').style.display = isSurvey ? 'block' : 'none';
                document.getElementById('op-time-to').style.display = isSurvey ? 'block' : 'none';
                
                document.getElementById('op-table-main').style.display = isSurvey ? 'none' : 'table';
                document.getElementById('op-table-survey').style.display = isSurvey ? 'table' : 'none';
                
                document.getElementById('op-chart-title').innerHTML = isSurvey ? 'Load survey (LS02) N/A sampling interval' : 'Operating Parameters Chart';
            };

            document.getElementById('back-to-meter-list').addEventListener('click', () => {
                document.getElementById('tariff-dashboard-view').style.display = 'block';
                document.getElementById('tariff-meter-detail').style.display = 'none';
            });

            function updateStatusUI(data) {
                if (!data.meter_status) return;

                const now = new Date();
                let connectedCount = 0;
                let readingCount = 0;
                
                // Track current connected states in STATE.meters for sorting
                data.meter_status.forEach(status => {
                    const rawStatus = (status.status || '').toLowerCase();
                    const isConnected = rawStatus === 'read_ok' || rawStatus === 'prelogin_ok' || rawStatus === 'connected' || rawStatus === 'functional' || rawStatus === 'reading';
                    const isFailed = rawStatus.includes('failed') || rawStatus.includes('timeout') || rawStatus === 'disconnected' || rawStatus === 'idle';
                    
                    const meter = STATE.meters.find(m => m.meter_id == status.meter_id);
                    if (meter) {
                        meter._isConnected = isConnected;
                        meter._statusText = isConnected ? 'Connected' : (isFailed ? 'Failed' : status.status);
                    }
                    if (isConnected) connectedCount++;
                    if (rawStatus === 'reading') readingCount++;
                });

                // Persist state
                localStorage.setItem('tariff_meters_cache', JSON.stringify(STATE.meters));
                localStorage.setItem('tariff_last_status', JSON.stringify(data));

                // Keep default order (sort by ID)
                STATE.meters.sort((a, b) => a.meter_id - b.meter_id);
                
                // Update Overview Numbers
                if (elements.statTotal) elements.statTotal.textContent = STATE.meters.length;
                if (elements.statConnected) elements.statConnected.textContent = connectedCount;
                if (elements.statDisconnected) elements.statDisconnected.textContent = STATE.meters.length - connectedCount;
                if (elements.statReading) elements.statReading.textContent = readingCount;
                
                // Re-render lists with new order
                renderMeterList();
                renderMeterManagement();
            }

            // --- Energy Reports Logic ---
            const energyElements = {
                year: document.getElementById('energy-year-select'),
                month: document.getElementById('energy-month-select'),
                table: document.getElementById('energy-breakdown-body'),
                historyTable: document.getElementById('status-history-body'),
                total: document.getElementById('energy-total-to-lmv'),
                bess: document.getElementById('energy-bess-to-lmv'),
                rts: document.getElementById('energy-rts-to-lmv'),
                inq: document.getElementById('energy-inqualified')
            };

            async function fetchEnergyReport() {
                const y = energyElements.year.value;
                const m = energyElements.month.value;
                if (energyElements.table) {
                    energyElements.table.innerHTML = '<tr><td colspan="9" style="text-align:center; padding:40px;"><div class="loader-ring" style="border-top-color:var(--primary-color)"></div></td></tr>';
                }

                try {
                    const sRes = await fetch(`${CONFIG.baseUrl}/energy/monthly-summary?year=${y}&month=${m}`);
                    const summary = await sRes.json();
                    if (summary.items && summary.items.length > 0) {
                        const item = summary.items[0];
                        const bessKwh = item.bess_to_lmv_energy_kwh || 0;
                        const rtsKwh = item.rfs_to_lmv_energy_kwh || 0;
                        const totalKwh = bessKwh + rtsKwh;

                        energyElements.total.textContent = totalKwh.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' kWh';
                        energyElements.bess.textContent = bessKwh.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' kWh';
                        energyElements.rts.textContent = rtsKwh.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' kWh';
                        energyElements.inq.textContent = item.number_of_inqualified_intervals || 0;
                    }

                    const bRes = await fetch(`${CONFIG.baseUrl}/energy/monthly-breakdown?year=${y}&month=${m}`);
                    const breakdown = await bRes.json();
                    renderEnergyTable(breakdown.items);
                } catch (e) {
                    console.error('Energy Report Error:', e);
                    if (energyElements.table) {
                        energyElements.table.innerHTML = '<tr><td colspan="9" style="text-align:center; padding:20px; color:var(--danger-color);">Error loading data.</td></tr>';
                    }
                }
            }

            async function fetchStatusHistory() {
                const y = energyElements.year.value;
                const m = energyElements.month.value;
                if (!energyElements.historyTable) return;
                
                energyElements.historyTable.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px;"><div class="loader-ring" style="border-top-color:var(--primary-color)"></div><p style="margin-top:10px; color:var(--text-secondary);">Loading status history...</p></td></tr>';

                try {
                    const response = await fetch(`${CONFIG.baseUrl}/faults/by-month?year=${y}&month=${m}`);
                    const data = await response.json();
                    STATE.historyData = data || [];
                    renderHistoryTable();
                } catch (e) {
                    console.error('Status History Error:', e);
                    energyElements.historyTable.innerHTML = `<tr><td colspan="5" style="text-align:center; padding:20px; color:var(--danger-color);">Error loading history: ${e.message}</td></tr>`;
                }
            }

            function renderEnergyTable(items) {
                if (!items || items.length === 0) {
                    energyElements.table.innerHTML = '<tr><td colspan="9" style="text-align:center; padding:20px;">No data available.</td></tr>';
                    return;
                }
                energyElements.table.innerHTML = items.map(item => {
                    const isFault = item.scenario_code !== 'ALL_OK';
                    const actionBtn = isFault ? `
                        <button class="btn-action view-fault-btn" 
                                data-start="${item.period_start}" 
                                data-end="${item.period_end}"
                                title="View faulty meters">
                            <i class="fa fa-eye"></i>
                        </button>
                    ` : '';
                    
                    const rowStyle = isFault ? 'style="background-color: #fee2e2;"' : '';
                    const mainVal = item.grid_energy_kwh || 0;
                    const bessVal = item.bess_to_lmv_kwh || 0;
                    const rtsVal = item.rts_to_lmv_kwh || 0;
                    const totalLmv = bessVal + rtsVal;

                    return `
                    <tr ${rowStyle}>
                        <td style="vertical-align: middle;">${new Date(item.period_start).toLocaleString()}</td>
                        <td style="vertical-align: middle;">${new Date(item.period_end).toLocaleString()}</td>
                        <td style="vertical-align: middle;"><span class="scenario-pill ${item.scenario_code === 'ALL_OK' ? 'normal' : 'warning'}">${item.scenario_code}</span></td>
                        <td style="vertical-align: middle;">${totalLmv.toFixed(2)}</td>
                        <td style="vertical-align: middle;">${mainVal.toFixed(2)}</td>
                        <td style="vertical-align: middle;">${(item.k_factor || 0).toFixed(2)}</td>
                        <td style="vertical-align: middle;">${bessVal.toFixed(2)}</td>
                        <td style="vertical-align: middle;">${rtsVal.toFixed(2)}</td>
                        <td style="text-align:center; vertical-align: middle;">
                            ${actionBtn}
                        </td>
                    </tr>
                `; }).join('');

                // Add event listeners to buttons
                energyElements.table.querySelectorAll('.view-fault-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const start = btn.getAttribute('data-start');
                        const end = btn.getAttribute('data-end');
                        showFaultInfo(start, end);
                    });
                });
            }

            function renderHistoryTable() {
                const scenarioWindows = STATE.historyData;
                if (!scenarioWindows || scenarioWindows.length === 0) {
                    energyElements.historyTable.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:20px; color:var(--text-secondary);">No history available for the selected period.</td></tr>';
                    return;
                }
                
                // Collect unique meters for filter
                const metersMap = new Map();
                let html = '';
                
                scenarioWindows.forEach(window => {
                    if (window.faults && window.faults.length > 0) {
                        window.faults.forEach(fault => {
                            // Populate filter map
                            metersMap.set(fault.meter_serial, fault.meter_name || 'N/A');

                            // Respect filter
                            if (STATE.selectedMeterFilter && String(fault.meter_serial) !== String(STATE.selectedMeterFilter)) return;

                             html += `
                                <tr style="vertical-align: middle;">
                                    <td style="padding:12px 16px; color:#64748b; vertical-align: middle; text-align: center;">${fault.meter_serial}</td>
                                    <td style="padding:12px 16px; font-weight:700; color:#001f8f; vertical-align: middle; text-align: center;">${fault.meter_name || 'N/A'}</td>
                                    <td style="padding:12px 16px; vertical-align: middle; text-align: center;"><span class="scenario-pill warning">${window.scenario_code}</span></td>
                                    <td style="padding:12px 16px; vertical-align: middle; text-align: center;">${new Date(fault.fault_start_ts).toLocaleString([], {year:'2-digit', month:'numeric', day:'numeric', hour:'numeric', minute:'2-digit'})}</td>
                                    <td style="padding:12px 16px; color:#64748b; vertical-align: middle; text-align: center;">${fault.fault_end_ts ? new Date(fault.fault_end_ts).toLocaleString([], {year:'2-digit', month:'numeric', day:'numeric', hour:'numeric', minute:'2-digit'}) : '--'}</td>
                                </tr>
                            `;
                        });
                    }
                });

                // Populate filter dropdown using ALL meters from STATE.meters
                const filterList = document.getElementById('meter-filter-list');
                if (filterList) {
                    const currentFilter = STATE.selectedMeterFilter;
                    let filterHtml = `<li><a href="javascript:void(0)" onclick="filterHistoryByMeter(null)">All Meters ${!currentFilter ? '✓' : ''}</a></li><li role="separator" class="divider"></li>`;
                    
                    // Sort meters by name
                    const sortedMeters = STATE.meters.map(m => [m.serial_number, m.meter_name || 'N/A']).sort((a, b) => a[1].localeCompare(b[1]));
                    
                    sortedMeters.forEach(([serial, name]) => {
                        const safeName = name.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                        filterHtml += `<li><a href="javascript:void(0)" onclick="filterHistoryByMeter('${serial}', '${safeName}')">${name} - ${serial} ${currentFilter === serial ? '✓' : ''}</a></li>`;
                    });
                    filterList.innerHTML = filterHtml;
                }

                if (html === '') {
                    energyElements.historyTable.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px; color:var(--success-color);"><i class="fa fa-check-circle-o" style="font-size:30px; margin-bottom:10px;"></i><p>All meters were healthy for the selected period.</p></td></tr>';
                } else {
                    energyElements.historyTable.innerHTML = html;
                }
            }

            window.filterHistoryByMeter = function(serial, name) {
                STATE.selectedMeterFilter = serial;
                const btn = document.getElementById('filter-by-meter-btn');
                if (btn) {
                    btn.innerHTML = serial ? `Filter: ${name || serial} <span class="caret"></span>` : `Filter by Meter <span class="caret"></span>`;
                }
                renderHistoryTable();
            };

            function updateStats() {
                if (elements.statTotal) elements.statTotal.textContent = STATE.meters.length;
            }

            // --- Meter Management JS Logic ---
            window.showMeterForm = function(editMeterId = null) {
                const formCard = document.getElementById('meter-form-card');
                const listCard = document.getElementById('meter-list-card');
                const addBtn = document.getElementById('add-meter-btn');
                const form = document.getElementById('meter-config-form');
                const modeInput = document.getElementById('meter-action-mode');
                const title = document.getElementById('meter-form-title');
                const submitBtn = document.getElementById('meter-submit-btn');

                form.reset();
                document.getElementById('meter-serial').readOnly = false;
                document.getElementById('meter-source').disabled = true;

                if (editMeterId !== null) {
                    const m = STATE.meters.find(x => x.meter_id === editMeterId);
                    if (!m) return;
                    
                    modeInput.value = 'edit';
                    document.getElementById('meter-edit-id').value = m.meter_id;
                    title.textContent = 'Edit Meter';
                    submitBtn.textContent = 'Update Meter';
                    
                    document.getElementById('meter-serial').value = m.serial_number || '';
                    document.getElementById('meter-serial').readOnly = true;
                    document.getElementById('meter-name').value = m.meter_name || '';
                    document.getElementById('meter-outstation').value = m.outstation || '';
                    document.getElementById('meter-username').value = m.username || '';
                    document.getElementById('meter-password').value = m.password || '';
                    document.getElementById('meter-type').value = m.type || '';
                    document.getElementById('meter-model').value = m.model || '';
                    document.getElementById('meter-role').value = m.role || '';
                    
                    if (m.survey_type && Array.isArray(m.survey_type)) {
                        document.getElementById('meter-survey').value = m.survey_type.join(', ');
                    }
                    
                    const roleId = Number(m.role || 0);
                    const selRole = STATE.roles.find(r => r.id === roleId);
                    if (selRole && selRole.name === 'SOURCE') {
                        document.getElementById('meter-source').disabled = false;
                        document.getElementById('meter-source').value = m.source_id || '';
                    }

                } else {
                    modeInput.value = 'add';
                    title.textContent = 'Add New Meter';
                    submitBtn.textContent = 'Add Meter';
                }

                formCard.style.display = 'block';
                listCard.style.display = 'none';
                if (addBtn) addBtn.style.display = 'none';
            };

            window.cancelMeterForm = function() {
                document.getElementById('meter-form-card').style.display = 'none';
                document.getElementById('meter-list-card').style.display = 'block';
                const addBtn = document.getElementById('add-meter-btn');
                if (addBtn) addBtn.style.display = 'inline-block';
            };

            window.handleRoleChange = function() {
                const roleSel = document.getElementById('meter-role');
                const sourceSel = document.getElementById('meter-source');
                const roleId = Number(roleSel.value || 0);
                const role = STATE.roles.find(r => r.id === roleId);
                
                if (role && role.name === 'SOURCE') {
                    sourceSel.disabled = false;
                } else {
                    sourceSel.disabled = true;
                    sourceSel.value = '';
                }
            };

            window.saveMeterConfig = async function(e) {
                e.preventDefault();
                const mode = document.getElementById('meter-action-mode').value;
                const submitBtn = document.getElementById('meter-submit-btn');
                
                const surveyVal = document.getElementById('meter-survey').value;
                const surveyArr = surveyVal ? surveyVal.split(',').map(s => s.trim()).filter(Boolean) : undefined;
                
                const payload = {
                    serial_number: Number(document.getElementById('meter-serial').value),
                    username: document.getElementById('meter-username').value,
                    password: document.getElementById('meter-password').value,
                    meter_name: document.getElementById('meter-name').value || undefined,
                    outstation: document.getElementById('meter-outstation').value ? Number(document.getElementById('meter-outstation').value) : undefined,
                    type: document.getElementById('meter-type').value,
                    model: document.getElementById('meter-model').value,
                    survey_type: surveyArr,
                    owner_id: Number(document.getElementById('meter-owner-id').value) || 1,
                    role: document.getElementById('meter-role').value ? Number(document.getElementById('meter-role').value) : undefined,
                    source_id: document.getElementById('meter-source').value ? Number(document.getElementById('meter-source').value) : undefined
                };

                const url = mode === 'add' ? `${CONFIG.baseUrl}/add_meter` : `${CONFIG.baseUrl}/update_meter`;
                const method = mode === 'add' ? 'POST' : 'PUT';
                
                try {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Saving...';
                    
                    const response = await fetch(url, {
                        method: method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    const resData = await response.json();
                    
                    if (!response.ok) {
                        alert(`Error: ${resData.detail || resData.status || 'Failed to save meter'}`);
                    } else {
                        // Success
                        cancelMeterForm();
                        // Refetch meters
                        fetchAllMeters();
                    }
                } catch (err) {
                    alert(`Network error saving meter: ${err.message}`);
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = mode === 'add' ? 'Add Meter' : 'Update Meter';
                }
            };

            window.deleteMeter = async function(meterId, serial) {
                if (!confirm(`Are you sure you want to delete meter ${serial}?`)) return;
                
                try {
                    const response = await fetch(`${CONFIG.baseUrl}/delete_meter/${meterId}`, {
                        method: 'DELETE' // Backend takes DELETE
                    });
                    
                    if (response.ok) {
                        fetchAllMeters();
                    } else {
                        const err = await response.json();
                        alert(`Failed to delete meter: ${err.detail || err.status}`);
                    }
                } catch (e) {
                    alert(`Network error: ${e.message}`);
                }
            };

            async function fetchOptions() {
                try {
                    const [resRoles, resSources] = await Promise.all([
                        fetch(`${CONFIG.baseUrl}/energy/roles`),
                        fetch(`${CONFIG.baseUrl}/energy/sources`)
                    ]);
                    
                    if (resRoles.ok) {
                        const r = await resRoles.json();
                        STATE.roles = r.items || [];
                        const roleSel = document.getElementById('meter-role');
                        if (roleSel) {
                            roleSel.innerHTML = '<option value="">None</option>' + STATE.roles.map(x => `<option value="${x.id}">${x.name}</option>`).join('');
                        }
                    }
                    if (resSources.ok) {
                        const s = await resSources.json();
                        STATE.sources = s.items || [];
                        const srcSel = document.getElementById('meter-source');
                        if (srcSel) {
                            srcSel.innerHTML = '<option value="">None</option>' + STATE.sources.map(x => `<option value="${x.id}">${x.name} (ID: ${x.id})</option>`).join('');
                        }
                    }
                } catch (e) {
                    console.error('Failed to load roles/sources:', e);
                }
            }

            // --- Initialization ---
            function startPolling() {
                // Initial fetch
                fetchAllMeters();
                pollStatus();
                fetchOptions();
                fetchYearlySummary();

                // Background polling
                setInterval(() => {
                    if (document.getElementById('meter-form-card').style.display !== 'none') {
                        // Skip refetching meters if the user is in the middle of editing/adding
                        pollStatus();
                    } else {
                        fetchAllMeters();
                        pollStatus();
                    }
                }, CONFIG.pollingInterval);
            }

            function init() {
                // Restore last status if available
                const lastStatus = localStorage.getItem('tariff_last_status');
                if (lastStatus) {
                    try {
                        const data = JSON.parse(lastStatus);
                        // We'll update the UI after meters are fetched/restored
                        setTimeout(() => updateStatusUI(data), 100);
                    } catch(e) {}
                }

                startPolling();

                // Tab switching
                document.querySelectorAll('.tab-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const tabId = btn.getAttribute('data-tab');
                        if (!tabId) return;

                        // Toggle Buttons
                        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');

                        // Toggle Content
                        document.querySelectorAll('.tab-content').forEach(content => {
                            content.classList.remove('active');
                            if (content.id === `tab-${tabId}`) content.classList.add('active');
                        });

                        // Fetch data for the selected tab
                        if (tabId === 'monthly-analysis') fetchEnergyReport();
                        if (tabId === 'status-history') fetchStatusHistory();
                    });
                });

                // Auto-fetch on selector change
                if (energyElements.year) energyElements.year.addEventListener('change', () => {
                   fetchEnergyReport();
                   fetchStatusHistory();
                });
                if (energyElements.month) energyElements.month.addEventListener('change', () => {
                   fetchEnergyReport();
                   fetchStatusHistory();
                });

                // Export CSV Listener
                const exportBtn = document.getElementById('export-energy-csv');
                if (exportBtn) {
                    exportBtn.addEventListener('click', () => {
                        const y = parseInt(energyElements.year.value, 10);
                        const m = parseInt(energyElements.month.value, 10);

                        // Start date is 1st of month at 00:00:00
                        const start = new Date(y, m - 1, 1);
                        // End date is 1st of NEXT month at 00:00:00 (exclusive)
                        const end = new Date(y, m, 1);
                        
                        const formatDt = (date) => {
                            const pad = n => n.toString().padStart(2, '0');
                            return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`;
                        };
                        
                        const fromTs = encodeURIComponent(formatDt(start));
                        const toTs = encodeURIComponent(formatDt(end));
                        
                        const downloadUrl = `${CONFIG.baseUrl}/energy/interval-raw/csv?from_ts=${fromTs}&to_ts=${toTs}`;
                        window.open(downloadUrl, '_blank');
                    });
                }

                // Initial fetch for energy sub-tabs
                fetchEnergyReport();
                fetchStatusHistory();
            }

            // --- Monthly Energy Chart ---
            let energyChart = null;

            window.fetchYearlySummary = async function() {
                const year = document.getElementById('chart-year-select').value;
                const chartDom = document.getElementById('monthly-energy-chart');
                if (!chartDom) return;

                if (!energyChart) {
                    energyChart = echarts.init(chartDom);
                }

                // Show loading
                energyChart.showLoading({
                    text: 'Loading…',
                    color: 'var(--primary-color)',
                    textColor: 'var(--text-secondary)',
                    maskColor: 'rgba(255,255,255,0.6)'
                });

                try {
                    const response = await fetch(`${CONFIG.baseUrl}/energy/yearly-summary?year=${year}`);
                    if (!response.ok) throw new Error('Failed to fetch yearly summary');
                    const data = await response.json();

                    const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                    const bessData = Array(12).fill(0);
                    const rtsData  = Array(12).fill(0);

                    let totalBess = 0;
                    let totalRts = 0;
                    let activeMonths = 0;

                    (data.items || []).forEach(item => {
                        const idx = item.month - 1;
                        if (idx >= 0 && idx < 12) {
                            const b = parseFloat((item.bess_to_lmv_energy_kwh || 0).toFixed(2));
                            const r = parseFloat((item.rts_to_lmv_energy_kwh  || 0).toFixed(2));
                            bessData[idx] = b;
                            rtsData[idx]  = r;
                            
                            totalBess += b;
                            totalRts += r;
                            if (b > 0 || r > 0 || item.number_of_inqualified_intervals > 0) {
                                activeMonths++;
                            }
                        }
                    });
                    
                    if (activeMonths === 0) activeMonths = 1; // avoid divide by zero for avg

                    const totalEnergy = totalBess + totalRts;
                    const avgEnergy = totalEnergy / activeMonths;

                    const yrTotalEl = document.getElementById('yearly-total-energy');
                    const yrBessEl = document.getElementById('yearly-bess-energy');
                    const yrRtsEl = document.getElementById('yearly-rts-energy');
                    const yrAvgEl = document.getElementById('yearly-avg-energy');

                    if (yrTotalEl) yrTotalEl.textContent = totalEnergy.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' kWh';
                    if (yrBessEl) yrBessEl.textContent = totalBess.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' kWh';
                    if (yrRtsEl) yrRtsEl.textContent = totalRts.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' kWh';
                    if (yrAvgEl) yrAvgEl.textContent = avgEnergy.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' kWh';

                    const option = {
                        tooltip: {
                            trigger: 'axis',
                            axisPointer: { type: 'shadow' },
                            formatter: function(params) {
                                let html = `<b>${params[0].axisValue}</b><br/>`;
                                params.forEach(p => {
                                    html += `<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${p.color};margin-right:5px;"></span>${p.seriesName}: <b>${p.value.toLocaleString()} kWh</b><br/>`;
                                });
                                return html;
                            }
                        },
                        legend: {
                            data: ['BESS to LMV', 'RTS to LMV'],
                            top: 0,
                            right: 0,
                            textStyle: { fontSize: 11, color: 'var(--text-secondary)' }
                        },
                        grid: { top: 28, left: 60, right: 20, bottom: 24 },
                        xAxis: {
                            type: 'category',
                            data: monthNames,
                            axisLine: { lineStyle: { color: 'var(--border-color)' } },
                            axisLabel: { fontSize: 11, color: 'var(--text-secondary)' }
                        },
                        yAxis: {
                            type: 'value',
                            name: 'kWh',
                            nameTextStyle: { fontSize: 10, color: 'var(--text-secondary)' },
                            axisLabel: {
                                fontSize: 10,
                                color: 'var(--text-secondary)',
                                formatter: v => v >= 1000 ? (v/1000).toFixed(1)+'k' : v
                            },
                            splitLine: { lineStyle: { color: 'var(--border-color)', type: 'dashed' } }
                        },
                        series: [
                            {
                                name: 'BESS to LMV',
                                type: 'bar',
                                stack: 'energy',
                                barMaxWidth: 40,
                                itemStyle: { color: '#3b82f6', borderRadius: [0,0,4,4] },
                                label: {
                                    show: false
                                },
                                data: bessData,
                                emphasis: { focus: 'series' }
                            },
                            {
                                name: 'RTS to LMV',
                                type: 'bar',
                                stack: 'energy',
                                barMaxWidth: 40,
                                itemStyle: { color: '#10b981', borderRadius: [4,4,0,0] },
                                label: {
                                    show: false
                                },
                                data: rtsData,
                                emphasis: { focus: 'series' }
                            }
                        ]
                    };

                    energyChart.hideLoading();
                    energyChart.setOption(option, true);

                    // Responsive resize
                    window.addEventListener('resize', () => energyChart && energyChart.resize());

                } catch (error) {
                    console.error('API Error (Yearly Summary):', error);
                    energyChart.hideLoading();
                }
            };

            // --- Operation Metrics JS Logic ---
            window.fetchFinalizedReadings = async function() {
                if (!STATE.currentMeterId) return;

                const year = document.getElementById('fn-year-select').value;
                const month = document.getElementById('fn-month-select').value;
                const importEl = document.getElementById('fn-import-val');
                const exportEl = document.getElementById('fn-export-val');

                if (importEl) importEl.textContent = '...';
                if (exportEl) exportEl.textContent = '...';

                try {
                    const response = await fetch(`${CONFIG.baseUrl}/energy/monthly-sum`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            meter_id: STATE.currentMeterId,
                            year: parseInt(year),
                            month: parseInt(month)
                        })
                    });

                    if (!response.ok) throw new Error('Failed to fetch finalized readings');
                    const data = await response.json();

                    if (importEl) importEl.textContent = (data.import || 0).toLocaleString(undefined, { minimumFractionDigits: 3 }) + ' kWh';
                    if (exportEl) exportEl.textContent = (data.export || 0).toLocaleString(undefined, { minimumFractionDigits: 3 }) + ' kWh';
                } catch (error) {
                    console.error('API Error (Finalized Readings):', error);
                    if (importEl) importEl.textContent = 'Error';
                    if (exportEl) exportEl.textContent = 'Error';
                }
            };

            window.fetchOperationMetrics = async function() {
                if (!STATE.currentMeterId) return;
                
                const btn = document.querySelector('#dtab-op-metrics .btn-apply');
                const origBtnHtml = btn.innerHTML;
                btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Loading...';
                btn.disabled = true;

                const fromDate = document.getElementById('op-from').value;
                const toDate = document.getElementById('op-to').value;
                const intervalVal = document.getElementById('op-interval').value; // '1m', '5m', '15m', 'survey'
                const timeFrom = document.getElementById('op-time-from').value || '00:00';
                const timeTo = document.getElementById('op-time-to').value || '23:59';
                
                let startIso, endIso;
                if (intervalVal === 'survey') {
                    startIso = new Date(`${fromDate}T${timeFrom}:00`).toISOString();
                    endIso = new Date(`${toDate}T${timeTo}:59`).toISOString();
                } else {
                    startIso = new Date(`${fromDate}T00:00:00`).toISOString();
                    endIso = new Date(`${toDate}T23:59:59`).toISOString();
                }

                let intervalSecs = null;
                if (intervalVal === '1m') intervalSecs = 60;
                if (intervalVal === '5m') intervalSecs = 300;
                if (intervalVal === '15m') intervalSecs = 900;

                const checkboxes = Array.from(document.querySelectorAll('#op-col-dropdown input[type="checkbox"]'));
                const checkedBoxes = document.querySelectorAll('#op-col-dropdown input[type="checkbox"]:checked');
                
                if (checkedBoxes.length === 0) {
                    alert('Please select at least one column.');
                    btn.innerHTML = origBtnHtml;
                    btn.disabled = false;
                    return;
                }

                // Collect only selected columns
                const selectedColumns = Array.from(checkedBoxes).map(c => c.value);

                const payload = {
                    meter_id: STATE.currentMeterId,
                    columns: selectedColumns,
                    time_range: { start_utc: startIso, end_utc: endIso },
                    order: 'asc',
                    limit: 10000,
                    interval_seconds: intervalSecs
                };

                try {
                    const res = await fetch(`${CONFIG.baseUrl}/query_data_by_time_range`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!res.ok) {
                        const err = await res.json();
                        throw new Error(err.detail && typeof err.detail === 'string' ? err.detail : JSON.stringify(err.detail || err));
                    }

                    const resData = await res.json();
                    const dataArr = resData.data || [];

                    renderOpChart(dataArr, selectedColumns);
                    renderOpTable(dataArr, checkboxes);

                } catch (e) {
                    console.error('Operation Metrics Fetch Error:', e);
                    document.querySelector('#op-table-main tbody').innerHTML = `<tr><td colspan="53" style="text-align:center; padding: 20px; color: var(--danger-color);">Error loading data: ${e.message}</td></tr>`;
                } finally {
                    btn.innerHTML = origBtnHtml;
                    btn.disabled = false;
                }
            };

            let opEchartInstance = null;
            function renderOpChart(dataArr, columns) {
                const chartDom = document.getElementById('op-chart');
                if (!opEchartInstance) {
                    opEchartInstance = echarts.init(chartDom);
                }
                
                if (!dataArr || dataArr.length === 0) {
                    opEchartInstance.clear();
                    opEchartInstance.setOption({
                        title: { text: 'No data found for the selected period', left: 'center', top: 'center', textStyle: { color: '#9ca3af', fontSize: 14, fontWeight: 'normal' } }
                    });
                    return;
                }

                const timestamps = dataArr.map(d => new Date(d.time_stamp).toLocaleString());
                
                const series = columns.map(col => {
                    const chk = document.querySelector(`#op-col-dropdown input[value="${col}"]`);
                    const name = chk ? chk.parentElement.textContent.trim() : col;
                    return {
                        name: name,
                        type: 'line',
                        data: dataArr.map(d => d[col]),
                        smooth: true,
                        showSymbol: false
                    };
                });

                const option = {
                    tooltip: { trigger: 'axis' },
                    legend: { 
                        data: series.map(s => s.name),
                        bottom: 0,
                        type: 'scroll'
                    },
                    grid: { left: '3%', right: '4%', bottom: '15%', containLabel: true },
                    xAxis: { type: 'category', boundaryGap: false, data: timestamps },
                    yAxis: { type: 'value' },
                    series: series
                };

                opEchartInstance.setOption(option, true);
            }

            function renderOpTable(dataArr, allCheckboxes) {
                const tbody = document.querySelector('#op-table-main tbody');
                if (!dataArr || dataArr.length === 0) {
                    const colspanStr = document.querySelector('#op-table-main tbody tr:first-child td').colSpan || 53;
                    tbody.innerHTML = `<tr><td colspan="${colspanStr}" style="text-align:center; padding: 40px; color: var(--text-secondary);">No Operation Metrics data found for this period.</td></tr>`;
                    return;
                }

                // We generate rows with all 52 columns so the alignment matches the multiselect visibility toggle.
                let html = '';
                dataArr.forEach(row => {
                    html += '<tr>';
                    html += `<td>${new Date(row.time_stamp).toLocaleString()}</td>`;
                    allCheckboxes.forEach(chk => {
                        const val = row[chk.value] !== undefined && row[chk.value] !== null ? row[chk.value] : '--';
                        html += `<td>${val}</td>`;
                    });
                    html += '</tr>';
                });

                tbody.innerHTML = html;
                window.updateOpMultiSelect(); // Apply column visibility to newly rendered cells
            }

            // --- Power Load Profile Logic ---

            window.handlePlCheckboxChange = function(cb) {
                const checkedBoxes = document.querySelectorAll('#pl-col-dropdown input[type="checkbox"]:checked');
                if (checkedBoxes.length > 10) {
                    alert('You can select up to 10 parameters at a time.');
                    cb.checked = false;
                    return;
                }
                updatePlMultiSelect();
            };

            window.togglePlMultiSelect = function(e) {
                if (e) e.stopPropagation();
                const drop = document.getElementById('pl-col-dropdown');
                drop.classList.toggle('show');
            };

            window.updatePlMultiSelect = function() {
                const list = document.querySelectorAll('#pl-col-dropdown input[type="checkbox"]');
                const checkedBoxes = Array.from(list).filter(c => c.checked);
                const table = document.getElementById('pl-table-main');
                const textEl = document.getElementById('pl-col-text');
                
                if (checkedBoxes.length === 0) {
                    textEl.textContent = 'None selected';
                    if (table) {
                        const trs = table.querySelectorAll('tr');
                        trs.forEach(tr => {
                            const cells = tr.children;
                            for (let i = 1; i < cells.length; i++) {
                                cells[i].style.display = 'none';
                            }
                        });
                        const colSpanStr = table.querySelector('tbody tr:first-child td')?.colSpan;
                        if (colSpanStr) {
                             table.querySelector('tbody tr:first-child td').colSpan = 1;
                        }
                    }
                    return;
                }
                
                const labels = checkedBoxes.map(c => c.parentElement.textContent.trim());
                if (labels.length <= 2) {
                    textEl.textContent = labels.join(', ');
                } else {
                    textEl.textContent = `${labels[0]}, ${labels[1]}, ...`;
                }

                if (table) {
                    const trs = table.querySelectorAll('tr');
                    // Ensure the empty state row is handled separately
                    const isEmptyState = table.querySelector('tbody').textContent.includes('No Power Load Profile');
                    if (isEmptyState && table.querySelector('tbody tr:first-child td')) {
                        table.querySelector('tbody tr:first-child td').colSpan = checkedBoxes.length + 1;
                        return;
                    }
                    
                    trs.forEach(tr => {
                        const cells = tr.children;
                        for (let i = 1; i < cells.length; i++) {
                            const colIndex = i - 1; 
                            if (colIndex < list.length) {
                                if (list[colIndex].checked) {
                                    cells[i].style.display = '';
                                } else {
                                    cells[i].style.display = 'none';
                                }
                            }
                        }
                    });
                }
            };
            
            document.addEventListener('click', function(e) {
                const plDrop = document.getElementById('pl-col-dropdown');
                if (plDrop && plDrop.classList.contains('show') && !e.target.closest('#pl-col-wrapper')) {
                    plDrop.classList.remove('show');
                }
            });

            window.fetchPowerLoadProfile = async function() {
                if (!STATE.currentMeterId) return;
                
                const btn = document.querySelector('#dtab-pl-profile .btn-apply');
                const origBtnHtml = btn.innerHTML;
                btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Loading...';
                btn.disabled = true;

                const fromDate = document.getElementById('pl-from').value;
                const toDate = document.getElementById('pl-to').value;
                const timeFrom = document.getElementById('pl-time-from').value || '00:00';
                const timeTo = document.getElementById('pl-time-to').value || '23:59';
                const survey = document.getElementById('pl-survey').value;

                if (!fromDate || !toDate) {
                    alert('Please select both From and To dates.');
                    btn.innerHTML = origBtnHtml;
                    btn.disabled = false;
                    return;
                }

                const startIso = `${fromDate}T${timeFrom}:00`;
                const endIso = `${toDate}T${timeTo}:59`;

                const checkboxes = Array.from(document.querySelectorAll('#pl-col-dropdown input[type="checkbox"]'));
                const checkedBoxes = Array.from(document.querySelectorAll('#pl-col-dropdown input[type="checkbox"]:checked'));
                
                if (checkedBoxes.length === 0) {
                    alert('Please select at least one column.');
                    btn.innerHTML = origBtnHtml;
                    btn.disabled = false;
                    return;
                }

                const payload = {
                    meter_id: STATE.currentMeterId,
                    survey: survey,
                    from_datetime: startIso,
                    to_datetime: endIso
                };

                try {
                    const res = await fetch(`${CONFIG.baseUrl}/read_profile`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!res.ok) {
                        const err = await res.json();
                        throw new Error(err.detail && typeof err.detail === 'string' ? err.detail : JSON.stringify(err.detail || err));
                    }

                    const resData = await res.json();
                    
                    const dataArr = resData.data || [];
                    const selectedColumns = checkedBoxes.map(c => c.value);

                    renderPlChart(dataArr, selectedColumns);
                    renderPlTable(dataArr, checkboxes);

                } catch (e) {
                    console.error('Power Load Profile Fetch Error:', e);
                    document.querySelector('#pl-table-main tbody').innerHTML = `<tr><td colspan="7" style="text-align:center; padding: 40px; color: var(--danger-color);">Error loading data: ${e.message}</td></tr>`;
                } finally {
                    btn.innerHTML = origBtnHtml;
                    btn.disabled = false;
                }
            };
            
            let plEchartInstance = null;
            function renderPlChart(dataArr, columns) {
                let chartDom = document.getElementById('pl-chart');
                if (!chartDom) {
                    const container = document.querySelector('#dtab-pl-profile .chart-container-pl');
                    const lines = container.querySelector('.grid-lines');
                    const xlbl = container.querySelector('.x-axis-label');
                    if (lines) lines.remove();
                    if (xlbl) xlbl.remove();
                    
                    chartDom = document.createElement('div');
                    chartDom.id = 'pl-chart';
                    chartDom.style.width = '100%';
                    chartDom.style.height = '350px';
                    chartDom.style.marginTop = '15px';
                    container.appendChild(chartDom);
                }

                if (!plEchartInstance) {
                    plEchartInstance = echarts.init(chartDom);
                }
                
                if (!dataArr || dataArr.length === 0) {
                    plEchartInstance.clear();
                    plEchartInstance.setOption({
                        title: { text: 'No profile data found for the selected period', left: 'center', top: 'center', textStyle: { color: '#9ca3af', fontSize: 14, fontWeight: 'normal' } }
                    });
                    return;
                }

                let timestamps = dataArr.map(d => {
                    const ts = d.time_stamp || d.DateTime || d.TIMESTAMP;
                    return ts ? new Date(ts).toLocaleString() : '??';
                });
                
                const series = columns.map(col => {
                    const chk = document.querySelector(`#pl-col-dropdown input[value="${col}"]`);
                    const name = chk ? chk.parentElement.textContent.trim() : col;
                    
                    // Filter: only numeric values for chart
                    const firstVal = dataArr[0][col];
                    const isPlottable = typeof firstVal === 'number' || (!isNaN(parseFloat(firstVal)) && isFinite(firstVal));
                    if (!isPlottable) return null;

                    return {
                        name: name,
                        type: 'line',
                        data: dataArr.map(d => {
                            let val = d[col];
                            if (typeof val === 'string') val = parseFloat(val);
                            return typeof val === 'number' && !Number.isInteger(val) ? parseFloat(val.toFixed(4)) : val;
                        }),
                        smooth: true,
                        showSymbol: false,
                    };
                }).filter(s => s !== null);

                const option = {
                    tooltip: { trigger: 'axis' },
                    legend: { 
                        data: series.map(s => s.name),
                        bottom: 0,
                        type: 'scroll'
                    },
                    grid: { left: '3%', right: '4%', bottom: '15%', containLabel: true },
                    xAxis: { type: 'category', boundaryGap: false, data: timestamps },
                    yAxis: { type: 'value' },
                    series: series
                };

                plEchartInstance.setOption(option, true);
            }

            function renderPlTable(dataArr, allCheckboxes) {
                const tbody = document.querySelector('#pl-table-main tbody');
                if (!dataArr || dataArr.length === 0) {
                    const colspanStr = document.querySelector('#pl-table-main tbody tr:first-child td')?.colSpan || 7;
                    tbody.innerHTML = `<tr><td colspan="${colspanStr}" style="text-align:center; padding: 40px; color: var(--text-secondary);">No Power Load Profile data found for this period.</td></tr>`;
                    return;
                }

                let html = '';
                dataArr.forEach(row => {
                    html += '<tr>';
                    html += `<td>${new Date(row.time_stamp || row.DateTime).toLocaleString()}</td>`;
                    allCheckboxes.forEach(chk => {
                        let val = row[chk.value] !== undefined && row[chk.value] !== null ? row[chk.value] : '--';
                        if (typeof val === 'number' && !Number.isInteger(val)) {
                            val = parseFloat(val.toFixed(4));
                        }
                        html += `<td>${val}</td>`;
                    });
                    html += '</tr>';
                });

                tbody.innerHTML = html;
                window.updatePlMultiSelect(); // Apply column visibility to newly rendered cells
            }

            init();
        })();
    </script>
</body>
</html>
