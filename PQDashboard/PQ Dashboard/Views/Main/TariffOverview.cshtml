                        <button type="button" class="btn btn-primary" id="close-fault-modal" data-dismiss="modal" style="background: #001f8f; border: none; padding: 8px 24px; font-weight: 700; border-radius: 8px; font-size: 14px; min-width: 100px; display: inline-flex; align-items: center; justify-content: center; line-height: 1;">Close</button>
                    </div>
                </div>
