                            <div style="border-left: 1px solid #cbd5e1; height: 16px;"></div>
                            <div style="display: flex; align-items: center; gap: 8px;">SCENARIO: <span id="modal-summary-scenario" class="scenario-pill warning" style="margin-left: 5px;">--</span></div>
